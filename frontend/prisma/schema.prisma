// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}


model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  pic       String?
  provider  String
  createdAt DateTime @default(now())
  role      Role     @default(customer)
}

enum Role {
  supplier
  customer
  driver
}

enum ShipmentStatus {
  PENDING
  IN_TRANSIT
  DELAYED
  REROUTED
  DELIVERED
  FAILED
}

enum CargoType {
  STANDARD_FREIGHT
  PERISHABLE_GOODS
  HAZARDOUS_MATERIALS
  FRAGILE_ITEMS
}

enum PriorityClass {
  STANDARD
  EXPRESS
  PRIORITY
}

enum EventType {
  LOCATION_UPDATE
  WEATHER_UPDATE
  TRAFFIC_UPDATE
  DELAY_DETECTED
  ANOMALY_DETECTED
  REROUTE_TRIGGERED
  PREDICTION
}

//////////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////////

model Shipment {
  id                 String          @id @default(cuid())
  source             String
  destination        String

  // Coordinates from Nominatim API
  source_lat         Float?
  source_lon         Float?
  destination_lat    Float?
  destination_lon    Float?

  status             ShipmentStatus  @default(PENDING)

  // Cargo specifications from create form
  weight_kg          Float?
  volume_m3          Float?
  cargo_type         CargoType       @default(STANDARD_FREIGHT)
  priority           PriorityClass   @default(STANDARD)

  // Scheduling
  scheduled_dispatch DateTime?
  notes              String?

  current_location   String?
  current_lat        Float?
  current_lon        Float?

  route_id           String?
  route              Route?          @relation(fields: [route_id], references: [id])

  estimated_delivery DateTime?
  actual_delivery    DateTime?

  metadata           Json?

  created_at         DateTime        @default(now())
  updated_at         DateTime        @updatedAt

  // Relations
  events             Event[]
  alerts             Alert[]
  locationLogs       LocationLog[]

  @@index([status])
}

//////////////////////////////////////////////////////

model Event {
  id           Int        @id @default(autoincrement())
  shipment_id  String
  shipment     Shipment   @relation(fields: [shipment_id], references: [id])

  timestamp    DateTime   @default(now())
  event_type   EventType
  data         Json
  severity     String

  @@index([shipment_id, timestamp])
}

//////////////////////////////////////////////////////

model Route {
  id              String    @id
  nodes           Json
  edges           Json
  total_distance  Float
  estimated_time  Float
  risk_score      Float     @default(0.0)
  created_at      DateTime  @default(now())

  shipments       Shipment[]
}

//////////////////////////////////////////////////////
model Alert {
  id           Int       @id @default(autoincrement())
  shipment_id  String?
  shipment     Shipment? @relation(fields: [shipment_id], references: [id])

  alert_type   String
  message      String
  is_resolved  Boolean   @default(false)

  created_at   DateTime  @default(now())
  resolved_at  DateTime?

  @@index([shipment_id])
}

//////////////////////////////////////////////////////

model LocationLog {
  id           Int       @id @default(autoincrement())
  shipment_id  String
  shipment     Shipment  @relation(fields: [shipment_id], references: [id])

  lat          Float
  lon          Float
  location     String?

  timestamp    DateTime  @default(now())

  @@index([shipment_id])
}

//////////////////////////////////////////////////////

model Prediction {
  id                      Int       @id @default(autoincrement())
  shipmentId              String?
  
  disruptionProbability   Float
  riskFactors             Json
  recommendedActions      Json

  createdAt               DateTime  @default(now())
}

//////////////////////////////////////////////////////

model OptimizationLog {
  id            Int      @id @default(autoincrement())

  source        String
  destination   String

  constraints   Json?
  resultRoute   Json

  createdAt     DateTime @default(now())
}

//////////////////////////////////////////////////////

model SystemHealth {
  id         Int      @id @default(autoincrement())
  status     String
  database   String
  redis      String
  neo4j      String
  timestamp  DateTime @default(now())
}